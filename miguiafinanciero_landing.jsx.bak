                        color: form.tipo === opt ? C.blue : C.gray,
                        transition: "all 0.25s ease",
                      }}>{opt}</button>
                    ))}
                  </div>
                </div>
                <button onClick={() => setEnviado(true)} style={{
                  width: "100%", padding: 18, border: "none", borderRadius: 16, cursor: "pointer",
                  background: `linear-gradient(135deg, ${C.green}, ${C.greenDark})`,
                  color: C.white, fontSize: 16, fontWeight: 800, letterSpacing: 0.4,
                  boxShadow: `0 8px 28px rgba(37,211,102,0.25), inset 0 1px 0 rgba(255,255,255,0.15)`,
                  transition: "all 0.25s ease",
                }}
                  onMouseEnter={e => { e.target.style.transform = "translateY(-2px)"; e.target.style.boxShadow = "0 12px 36px rgba(37,211,102,0.3)"; }}
                  onMouseLeave={e => { e.target.style.transform = "translateY(0)"; e.target.style.boxShadow = "0 8px 28px rgba(37,211,102,0.25)"; }}
                >QUIERO MI ANÁLISIS GRATIS →</button>
                <p style={{ color: C.grayLight, fontSize: 11, textAlign: "center", marginTop: 16 }}>🔒 Tus datos son 100% confidenciales.</p>
              </div>
            ) : (
              <div style={{
                background: C.white, borderRadius: 28, padding: 52, textAlign: "center",
                border: `2px solid ${C.green}`, animation: "fadeUp 0.5s ease",
                boxShadow: "0 20px 60px rgba(37,211,102,0.08)",
              }}>
                <div style={{
                  width: 72, height: 72, borderRadius: "50%",
                  background: `linear-gradient(135deg, ${C.green}, ${C.greenDark})`,
                  display: "flex", alignItems: "center", justifyContent: "center",
                  margin: "0 auto 22px", fontSize: 34, color: C.white,
                  boxShadow: "0 8px 24px rgba(37,211,102,0.2)",
                }}>✓</div>
                <h3 style={{ fontSize: 24, fontWeight: 900, marginBottom: 14, fontFamily: "'Merriweather', serif", color: C.blue }}>
                  ¡Recibido, {form.nombre || "amigo"}!
                </h3>
                <p style={{ color: C.gray, fontSize: 15, lineHeight: 1.75 }}>
                  En menos de 24 horas te contactaremos por WhatsApp con tu análisis personalizado. Prepara tu último extracto bancario.
                </p>
              </div>
            )}
          </div>
        </FadeIn>
      </Section>

      {/* ═══════════════════ URGENCIA FINAL ═══════════════════ */}
      <section style={{ padding: "80px 28px", background: C.cream }}>
        <FadeIn>
          <div style={{
            maxWidth: 680, margin: "0 auto", padding: "52px 44px", borderRadius: 28, textAlign: "center",
            background: `linear-gradient(150deg, ${C.white}, ${C.cream})`,
            border: `2px solid ${C.yellow}`,
            boxShadow: `0 16px 50px ${C.yellowSoft}`,
            position: "relative", overflow: "hidden",
          }}>
            <div style={{ position: "absolute", top: -20, left: -20, width: 100, height: 100, borderRadius: "50%", background: C.yellowGlow, pointerEvents: "none" }} />
            <h3 style={{ color: C.blue, fontSize: "clamp(20px, 3vw, 26px)", fontWeight: 900, margin: "0 0 12px", fontFamily: "'Merriweather', serif", position: "relative" }}>
              Mientras decides, tu deuda sigue creciendo.
            </h3>
            <p style={{ color: C.gray, fontSize: 15, margin: "0 0 30px", lineHeight: 1.7, position: "relative" }}>
              Cada día sin reestructurar es dinero que le regalas al banco. El análisis es gratis. La decisión es tuya.
            </p>
            <button onClick={() => scrollTo(contactRef)} style={{
              padding: "17px 42px", borderRadius: 16, border: "none", cursor: "pointer",
              background: `linear-gradient(135deg, ${C.blue}, ${C.blueDark})`,
              color: C.yellow, fontSize: 16, fontWeight: 800, letterSpacing: 0.4,
              boxShadow: "0 6px 24px rgba(30,58,95,0.2)",
              transition: "all 0.3s ease", position: "relative",
            }}
              onMouseEnter={e => { e.target.style.transform = "translateY(-2px)"; e.target.style.boxShadow = "0 10px 32px rgba(30,58,95,0.25)"; }}
              onMouseLeave={e => { e.target.style.transform = "translateY(0)"; e.target.style.boxShadow = "0 6px 24px rgba(30,58,95,0.2)"; }}
            >SOLICITAR ANÁLISIS GRATIS AHORA</button>
          </div>
        </FadeIn>
      </section>

      {/* ═══════════════════ FOOTER ═══════════════════ */}
      <footer style={{
        padding: "52px 28px 32px",
        background: `linear-gradient(135deg, ${C.blue}, ${C.blueDark})`,
        textAlign: "center", position: "relative", overflow: "hidden",
      }}>
        <div style={{ position: "absolute", inset: 0, opacity: 0.03, backgroundImage: `radial-gradient(circle, ${C.yellow} 1px, transparent 1px)`, backgroundSize: "28px 28px", pointerEvents: "none" }} />
        <div style={{ position: "relative", zIndex: 1 }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 10, marginBottom: 16 }}>
            <div style={{
              width: 36, height: 36, borderRadius: 10, background: C.yellow,
              display: "flex", alignItems: "center", justifyContent: "center",
              fontWeight: 900, color: C.blue, fontSize: 13, fontFamily: "'Merriweather', serif",
            }}>MG</div>
            <span style={{ fontFamily: "'Merriweather', serif", fontSize: 16, fontWeight: 700, color: C.white }}>
              Mi Guía <span style={{ color: C.yellow }}>Financiero</span>
            </span>
          </div>
          <p style={{ color: "rgba(255,255,255,0.45)", fontSize: 12, margin: "0 0 8px" }}>
            Especialistas en reestructuración de créditos hipotecarios bajo la Ley 546 de 1999
          </p>
          <p style={{ color: "rgba(255,255,255,0.2)", fontSize: 11, margin: 0 }}>
            © 2026 MiGuiaFinanciero.com — Todos los derechos reservados
          </p>
        </div>
      </footer>
    </div>
  );
}
